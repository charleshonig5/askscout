{
  "name": "askscout-monorepo",
  "description": "askscout monorepo — CLI (askscout), shared library (askscout-core), and web app (askscout-web).",
  "license": "MIT",
  "author": "Charles Honig <charleshonigdesign@gmail.com>",
  "homepage": "https://askscout.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/charleshonig5/askscout.git"
  },
  "bugs": {
    "url": "https://github.com/charleshonig5/askscout/issues"
  },
  "private": true,
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel run dev",
    "typecheck": "tsc --build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.4",
    "@eslint/js": "^9.24.0",
    "@next/eslint-plugin-next": "^16.2.2",
    "eslint": "^9.24.0",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.1.1"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
