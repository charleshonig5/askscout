{
  "name": "askscout-core",
  "version": "0.1.0",
  "description": "Shared library powering askscout — git reading, LLM digest summarization, output formatting, and project state management.",
  "license": "MIT",
  "author": "Charles Honig <charleshonigdesign@gmail.com>",
  "homepage": "https://askscout.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/charleshonig5/askscout.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/charleshonig5/askscout/issues"
  },
  "keywords": [
    "askscout",
    "git",
    "digest",
    "llm",
    "developer-tools"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "^3.2.4"
  }
}
